{
  "openapi": "3.0.0",
  "info": {
    "title": "User Portal API",
    "version": "1.0.0",
    "description": "API documentation for the User Portal Backend"
  },
  "servers": [
    {
      "url": "http://localhost:3000/api",
      "description": "Local development server"
    }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "token",
        "description": "JWT stored in an HttpOnly cookie named token. Swagger UI might not send cookies directly depending on browser settings."
      }
    }
  },
  "paths": {
    "/auth/signup": {
      "post": {
        "summary": "Register a new user",
        "description": "Creates a new user account with the provided details.",
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "fullName",
                  "username",
                  "email",
                  "password"
                ],
                "properties": {
                  "fullName": {
                    "type": "string",
                    "example": "John Doe",
                    "minLength": 2
                  },
                  "username": {
                    "type": "string",
                    "example": "johndoe123",
                    "minLength": 3
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "john@example.com"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "example": "strongpassword123",
                    "minLength": 6
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User registered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "User registered successfully"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string",
                          "example": "60d0fe4f5311236168a109ca"
                        },
                        "fullName": {
                          "type": "string",
                          "example": "John Doe"
                        },
                        "username": {
                          "type": "string",
                          "example": "johndoe123"
                        },
                        "email": {
                          "type": "string",
                          "example": "john@example.com"
                        },
                        "createdAt": {
                          "type": "string",
                          "format": "date-time"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation failed or user already exists"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Authenticate a user",
        "description": "Logs in a user with their email or username and password.",
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "identifier",
                  "password"
                ],
                "properties": {
                  "identifier": {
                    "type": "string",
                    "example": "johndoe123",
                    "description": "Email or Username"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "example": "strongpassword123"
                  },
                  "rememberMe": {
                    "type": "boolean",
                    "example": true,
                    "description": "Extended session for 30 days"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful - sets token cookie",
            "headers": {
              "Set-Cookie": {
                "schema": {
                  "type": "string"
                },
                "description": "token=abcde..."
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Login successful"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation failed"
          },
          "401": {
            "description": "Invalid credentials"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "summary": "Log out user",
        "description": "Clears the authentication token cookie.",
        "tags": [
          "Auth"
        ],
        "responses": {
          "200": {
            "description": "Logged out successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Logged out successfully"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/auth/profile": {
      "get": {
        "summary": "Get User Profile",
        "description": "Returns the profile of the currently authenticated user.",
        "tags": [
          "Auth"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "User profile successfully retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "User details retrieved successfully"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string",
                          "example": "60d0fe4f5311236168a109ca"
                        },
                        "fullName": {
                          "type": "string",
                          "example": "John Doe"
                        },
                        "username": {
                          "type": "string",
                          "example": "johndoe123"
                        },
                        "email": {
                          "type": "string",
                          "example": "john@example.com"
                        },
                        "createdAt": {
                          "type": "string",
                          "format": "date-time"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized / User not authenticated"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/documents": {
      "get": {
        "summary": "Get User Documents",
        "description": "Retrieve all uploaded documents for the currently logged-in user.",
        "tags": [
          "Documents"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved documents",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Documents retrieved successfully"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "documentType": {
                            "type": "string",
                            "example": "RESUME"
                          },
                          "uploadStatus": {
                            "type": "string",
                            "example": "PROCESSING"
                          },
                          "files": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "s3Key": {
                                  "type": "string",
                                  "example": "truuth/uploads/users/123/456-resume.pdf"
                                },
                                "documentName": {
                                  "type": "string",
                                  "example": "resume.pdf"
                                },
                                "documentUrl": {
                                  "type": "string",
                                  "example": "https://s3.amazonaws.com/my-bucket/..."
                                },
                                "mimeType": {
                                  "type": "string",
                                  "example": "application/pdf"
                                },
                                "status": {
                                  "type": "string",
                                  "example": "UPLOADED"
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Server error"
          }
        }
      },
      "post": {
        "summary": "Save Document Record",
        "description": "Save the metadata of an uploaded document to the backend once the direct S3 upload finishes.",
        "tags": [
          "Documents"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "documentType",
                  "files"
                ],
                "properties": {
                  "documentType": {
                    "type": "string",
                    "example": "RESUME",
                    "description": "Accepted values: PASSPORT, DRIVERS_LICENCE, RESUME, OTHER"
                  },
                  "files": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": [
                        "documentUrl",
                        "documentName",
                        "s3Key",
                        "mimeType"
                      ],
                      "properties": {
                        "documentUrl": {
                          "type": "string",
                          "example": "https://s3.amazonaws.com/my-bucket/..."
                        },
                        "documentName": {
                          "type": "string",
                          "example": "resume.pdf"
                        },
                        "s3Key": {
                          "type": "string",
                          "example": "truuth/uploads/users/123/456-resume.pdf"
                        },
                        "mimeType": {
                          "type": "string",
                          "example": "application/pdf"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Document record saved completely",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Document record saved successfully"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid payload or document type"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/documents/presigned-url": {
      "post": {
        "summary": "Generate Pre-signed S3 URL",
        "description": "Generates a pre-signed URL to upload a document directly to S3.",
        "tags": [
          "Documents"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "fileName",
                  "contentType"
                ],
                "properties": {
                  "fileName": {
                    "type": "string",
                    "example": "resume.pdf"
                  },
                  "contentType": {
                    "type": "string",
                    "example": "application/pdf"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Pre-signed URL generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Pre-signed URL generated successfully"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "uploadUrl": {
                          "type": "string",
                          "example": "https://s3.amazonaws.com/my-bucket/truuth/..."
                        },
                        "s3Key": {
                          "type": "string",
                          "example": "truuth/uploads/users/123/456-resume.pdf"
                        },
                        "publicUrl": {
                          "type": "string",
                          "example": "https://my-bucket.s3.ap-southeast-2.amazonaws.com/truuth/..."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing file name or content type"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    }
  }
}